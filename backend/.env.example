# ReadGenius Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================
# OPTION 1: Ollama (Recommended - Completely Free)
# =============================================
# Install Ollama from: https://ollama.ai
# Then run: ollama pull llama3.2
# 
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =============================================
# OPTION 2: Groq API (Free Tier Available)
# =============================================
# Sign up at: https://console.groq.com
# Free tier includes: 30 requests/min, 14,400 requests/day
# 
# GROQ_API_KEY=your-groq-api-key-here

# =============================================
# No API Key Required for Basic Features
# =============================================
# - Dictionary lookup uses Free Dictionary API (always free)
# - PDF reading works offline (local storage)
# - Only AI features need Ollama or Groq
